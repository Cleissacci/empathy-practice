# Copy this file to ".env" and fill in your real key.
#   cp .env.example .env      (macOS/Linux)
#   Copy-Item .env.example .env   (Windows PowerShell)
#
# The .env file is git-ignored so your key is never committed.
# On Vercel, set these same variables in Settings → Environment Variables instead.

# Required — your Google Gemini API key (https://aistudio.google.com/apikey).
# Powers both the roleplay conversation text and the spoken voices.
GEMINI_API_KEY=

# Optional — chat model for roleplay replies + grading (default: gemini-3.1-flash-lite).
# Fast (~1.2s). For higher quality at ~5s, use gemini-3.5-flash.
# GEMINI_MODEL=gemini-3.1-flash-lite

# Optional — text-to-speech model for the voices (default: gemini-2.5-flash-preview-tts).
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
